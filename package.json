{
  "name": "@audio/defeedback",
  "version": "1.1.2",
  "type": "module",
  "sideEffects": false,
  "description": "Adaptive feedback suppression — umbrella for @audio/defeedback-* atoms (analyzer, tracker, notch bank)",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "audio",
    "dsp",
    "feedback",
    "howling",
    "notch",
    "live-sound"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./audio": "./audio.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "audio.js"
  ],
  "scripts": {
    "test": "node test.js",
    "test:all": "npm test --workspaces --if-present && npm test",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "dependencies": {
    "@audio/defeedback-analyzer": "^1.0.0",
    "@audio/defeedback-tracker": "^1.0.0",
    "@audio/defeedback-notchbank": "^1.0.0"
  },
  "devDependencies": {
    "tst": "^9.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/defeedback.git"
  },
  "funding": "https://github.com/sponsors/audiojs"
}
